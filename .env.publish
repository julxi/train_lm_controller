# ssh stuff
SSH_IDENTITY_FILE=~/.ssh/id_rsa
SSH_CONFIG_DIR=~/.ssh/config.d
SSH_CONFIG_NAME=lm_controller.conf
SSH_USER=root
SSH_HOST_ALIAS=lm_controller

# repo stuff
REPO_URL=https://github.com/julxi/train_lm_controller.git
REPO_NAME=train_lm_controller

# remote stuff
REMOTE_WORKDIR=/workspace
REMOTE_PYTHON=/venv/main/bin/python